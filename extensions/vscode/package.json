{
  "$schema": "./package.schema.json",
  "name": "soroban-debugger",
  "displayName": "Soroban Debugger",
  "description": "Debug adapter for Soroban smart contracts with breakpoints, variable inspection, and call stack visualization",
  "version": "0.1.0",
  "author": "Soroban Team",
  "publisher": "soroban",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Timi16/soroban-debugger.git"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Debuggers"
  ],
  "keywords": [
    "soroban",
    "stellar",
    "debug",
    "debugger",
    "smart-contract"
  ],
  "activationEvents": [
    "onDebugResolve:soroban"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "soroban-debugger.runLaunchPreflight",
        "title": "Run Launch Preflight Check",
        "category": "Soroban"
      },
      {
        "command": "soroban-debugger.diagnoseSourceMap",
        "title": "Diagnose Source Map Health",
        "category": "Soroban"
      },
      {
        "command": "soroban-debugger.openDocs",
        "title": "Quick-Open Documentation",
        "category": "Soroban"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "soroban-debugger",
          "title": "Soroban Debugger",
          "icon": "$(debug-console)"
        }
      ]
    },
    "views": {
      "soroban-debugger": [
        {
          "id": "soroban-debugger.eventsView",
          "name": "Contract Events",
          "contextualTitle": "Soroban"
        }
      ]
    },
    "configuration": {
      "title": "Soroban Debugger",
      "properties": {
        "soroban-debugger.requestTimeoutMs": {
          "type": "number",
          "default": 30000,
          "description": "Per-request timeout (ms) for backend wire-protocol calls before the debug session fails as unhealthy."
        },
        "soroban-debugger.connectTimeoutMs": {
          "type": "number",
          "default": 10000,
          "description": "Timeout for connecting to the debugger server (ms)."
        },
        "soroban-debugger.defaultContractPath": {
          "type": "string",
          "default": "${workspaceFolder}/target/wasm32-unknown-unknown/release/contract.wasm",
          "description": "Default path to the contract WASM file."
        },
        "soroban-debugger.defaultSnapshotPath": {
          "type": "string",
          "default": "${workspaceFolder}/snapshot.json",
          "description": "Default path to the network snapshot JSON file."
        },
        "soroban-debugger.telemetry.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable opt-in telemetry for launch failures, handshake errors, and adapter crashes. No contract data or secrets are collected."
        }
      }
    },
    "debuggers": [
      {
        "type": "soroban",
        "label": "Soroban",
        "program": "./dist/debugAdapter.js",
        "runtime": "node",
        "languages": [
          "rust"
        ],
        "configurationAttributes": {
          "launch": {
            "required": [
              "contractPath"
            ],
            "properties": {
              "contractPath": {
                "type": "string",
                "description": "Path to a readable Soroban contract WASM file",
                "default": "${workspaceFolder}/target/wasm32-unknown-unknown/release/contract.wasm"
              },
              "snapshotPath": {
                "type": "string",
                "description": "Optional path to a readable snapshot JSON file for simulator state",
                "default": "${workspaceFolder}/snapshot.json"
              },
              "entrypoint": {
                "type": "string",
                "description": "Non-empty smart contract function name to debug",
                "default": "main"
              },
              "args": {
                "type": "array",
                "description": "JSON-serializable arguments to pass to the contract function",
                "default": []
              },
              "trace": {
                "type": "boolean",
                "description": "Enable detailed trace logging",
                "default": false
              },
              "binaryPath": {
                "type": "string",
                "description": "Optional path to a readable soroban-debug binary to launch"
              },
              "port": {
                "type": "integer",
                "description": "Optional TCP port for the debugger server. Must be between 1 and 65535.",
                "minimum": 1,
                "maximum": 65535
              },
              "token": {
                "type": "string",
                "description": "Optional single-line authentication token for the debugger server.",
                "minLength": 1,
                "pattern": ".*\\S.*"
              },
              "tlsCert": {
                "type": "string",
                "description": "Optional path to a TLS certificate file for secure server connections.",
                "pattern": ".*\\S.*"
              },
              "tlsKey": {
                "type": "string",
                "description": "Optional path to a TLS private key file for secure server connections.",
                "pattern": ".*\\S.*"
              },
              "storageFilter": {
                "type": "array",
                "description": "Filter storage view to only show keys matching pattern (e.g. ['balance:*', 're:^contract_.*']).",
                "items": {
                  "type": "string"
                },
                "default": []
              },
              "repeat": {
                "type": "integer",
                "description": "Repeat execution N times and show throughput/latency stats in the Debug Console.",
                "minimum": 1,
                "default": 1
              },
              "batchArgs": {
                "type": "string",
                "description": "Path to a JSON file containing an array of argument sets for batch execution. Each entry is executed as a separate run with its own args."
              },
              "showEvents": {
                "type": "boolean",
                "description": "Stream contract events to the debug console output channel during execution.",
                "default": false
              },
              "eventFilter": {
                "type": "array",
                "description": "Optional event filter patterns. Use plain substring patterns or regex patterns with the prefix 're:'.",
                "items": {
                  "type": "string"
                },
                "default": []
              },
              "mock": {
                "type": "array",
                "description": "Mock cross-contract return specs in the format CONTRACT_ID.function=return_value.",
                "items": {
                  "type": "string"
                },
                "default": []
              }
            }
          },
          "attach": {
            "required": [
              "contractPath",
              "port"
            ],
            "properties": {
              "host": {
                "type": "string",
                "description": "Hostname or IP address of the already-running soroban-debug server.",
                "default": "127.0.0.1"
              },
              "port": {
                "type": "integer",
                "description": "TCP port of the already-running soroban-debug server. Must be between 1 and 65535.",
                "minimum": 1,
                "maximum": 65535
              },
              "contractPath": {
                "type": "string",
                "description": "Path to a readable Soroban contract WASM file",
                "default": "${workspaceFolder}/target/wasm32-unknown-unknown/release/contract.wasm"
              },
              "snapshotPath": {
                "type": "string",
                "description": "Optional path to a readable snapshot JSON file for simulator state",
                "default": "${workspaceFolder}/snapshot.json"
              },
              "entrypoint": {
                "type": "string",
                "description": "Non-empty smart contract function name to debug",
                "default": "main"
              },
              "args": {
                "type": "array",
                "description": "JSON-serializable arguments to pass to the contract function",
                "default": []
              },
              "token": {
                "type": "string",
                "description": "Optional single-line authentication token for the remote debugger server.",
                "minLength": 1,
                "pattern": ".*\\S.*"
              },
              "tlsCert": {
                "type": "string",
                "description": "Optional path to a TLS certificate file for secure remote connections.",
                "pattern": ".*\\S.*"
              },
              "tlsKey": {
                "type": "string",
                "description": "Optional path to a TLS private key file for secure remote connections.",
                "pattern": ".*\\S.*"
              },
              "trace": {
                "type": "boolean",
                "description": "Enable detailed trace logging",
                "default": false
              },
              "requestTimeoutMs": {
                "type": "number",
                "description": "Per-request timeout (ms) for backend wire-protocol calls.",
                "default": 30000
              },
              "connectTimeoutMs": {
                "type": "number",
                "description": "Timeout (ms) to wait for the remote server to become reachable.",
                "default": 10000
              },
              "storageFilter": {
                "type": "array",
                "description": "Filter storage view to only show keys matching pattern.",
                "items": {
                  "type": "string"
                },
                "default": []
              },
              "repeat": {
                "type": "integer",
                "description": "Repeat execution N times and show throughput/latency stats.",
                "minimum": 1,
                "default": 1
              },
              "showEvents": {
                "type": "boolean",
                "description": "Stream contract events to the debug console output channel during execution.",
                "default": false
              },
              "eventFilter": {
                "type": "array",
                "description": "Optional event filter patterns. Use plain substring patterns or regex patterns with the prefix 're:'.",
                "items": {
                  "type": "string"
                },
                "default": []
              },
              "mock": {
                "type": "array",
                "description": "Mock cross-contract return specs in the format CONTRACT_ID.function=return_value.",
                "items": {
                  "type": "string"
                },
                "default": []
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "name": "Soroban: Debug Contract",
            "type": "soroban",
            "request": "launch",
            "contractPath": "${workspaceFolder}/target/wasm32-unknown-unknown/release/contract.wasm",
            "snapshotPath": "${workspaceFolder}/snapshot.json",
            "entrypoint": "main",
            "args": [],
            "trace": false,
            "showEvents": false,
            "eventFilter": [],
            "mock": [],
            "binaryPath": "${workspaceFolder}/target/debug/soroban-debug"
          }
        ],
        "configurationSnippets": [
          {
            "label": "Soroban: Debug Contract",
            "description": "Launch Soroban contract debugger",
            "body": {
              "name": "Soroban: Debug Contract",
              "type": "soroban",
              "request": "launch",
              "contractPath": "${workspaceFolder}/target/wasm32-unknown-unknown/release/contract.wasm",
              "snapshotPath": "${workspaceFolder}/snapshot.json",
              "entrypoint": "main",
              "args": [],
              "trace": false,
              "showEvents": false,
              "eventFilter": [],
              "mock": [],
              "binaryPath": "${workspaceFolder}/target/debug/soroban-debug"
            }
          },
          {
            "label": "Soroban: Attach to Remote Debugger",
            "description": "Attach to an already-running soroban-debug server",
            "body": {
              "name": "Soroban: Attach to Remote Debugger",
              "type": "soroban",
              "request": "attach",
              "host": "127.0.0.1",
              "port": 2345,
              "contractPath": "${workspaceFolder}/target/wasm32-unknown-unknown/release/contract.wasm",
              "entrypoint": "main",
              "args": []
            }
          }
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "build:manifest": "node ./src/test/distDriftGuard.js --write-manifest",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "build": "npm run compile && npm run build:manifest",
    "check:dist": "node ./src/test/distDriftGuard.js",
    "test": "npm run test:smoke && npm run test:dap-e2e",
    "ci": "npm run build && npm run check:dist && npm run test",
    "test:all": "node ./dist/test/runTest.js",
    "test:smoke": "node ./dist/test/runSmokeTest.js",
    "test:dap-e2e": "node ./dist/test/runDapE2E.js",
    "test:dap-e2e:repeat": "node ./dist/test/runDapE2E.js --repeat 10"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "@types/vscode": "^1.75.0",
    "@vscode/debugprotocol": "^1.65.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@vscode/debugadapter": "^1.65.0",
    "events": "^3.3.0"
  }
}
