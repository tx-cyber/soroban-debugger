{
  "name": "soroban-debugger",
  "displayName": "Soroban Debugger",
  "description": "Debug adapter for Soroban smart contracts with breakpoints, variable inspection, and call stack visualization",
  "version": "0.1.0",
  "author": "Soroban Team",
  "publisher": "soroban",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/stellar/soroban-debugger.git"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Debuggers"
  ],
  "keywords": [
    "soroban",
    "stellar",
    "debug",
    "debugger",
    "smart-contract"
  ],
  "activationEvents": [
    "onDebugResolve:soroban"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Soroban Debugger",
      "properties": {
        "soroban-debugger.requestTimeoutMs": {
          "type": "number",
          "default": 30000,
          "description": "Per-request timeout (ms) for backend wire-protocol calls before the debug session fails as unhealthy."
        },
        "soroban-debugger.connectTimeoutMs": {
          "type": "number",
          "default": 10000,
          "description": "Timeout (ms) to wait for the backend server to become reachable during launch."
        }
      }
    },
    "debuggers": [
      {
        "type": "soroban",
        "label": "Soroban",
        "program": "./dist/debugAdapter.js",
        "runtime": "node",
        "languages": [
          "rust"
        ],
        "configurationAttributes": {
          "launch": {
            "required": [
              "contractPath"
            ],
            "properties": {
              "contractPath": {
                "type": "string",
                "description": "Path to a readable Soroban contract WASM file",
                "default": "${workspaceFolder}/target/wasm32-unknown-unknown/release/contract.wasm"
              },
              "snapshotPath": {
                "type": "string",
                "description": "Optional path to a readable snapshot JSON file for simulator state",
                "default": "${workspaceFolder}/snapshot.json"
              },
              "entrypoint": {
                "type": "string",
                "description": "Non-empty smart contract function name to debug",
                "default": "main"
              },
              "args": {
                "type": "array",
                "description": "JSON-serializable arguments to pass to the contract function",
                "default": []
              },
              "trace": {
                "type": "boolean",
                "description": "Enable detailed trace logging",
                "default": false
              },
              "binaryPath": {
                "type": "string",
                "description": "Optional path to a readable soroban-debug binary to launch"
              },
              "port": {
                "type": "integer",
                "description": "Optional TCP port for the debugger server. Must be between 1 and 65535.",
                "minimum": 1,
                "maximum": 65535
              },
              "token": {
                "type": "string",
                "description": "Optional single-line authentication token for the debugger server.",
                "minLength": 1,
                "pattern": ".*\\S.*"
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "name": "Soroban: Debug Contract",
            "type": "soroban",
            "request": "launch",
            "contractPath": "${workspaceFolder}/target/wasm32-unknown-unknown/release/contract.wasm",
            "snapshotPath": "${workspaceFolder}/snapshot.json",
            "entrypoint": "main",
            "args": [],
            "trace": false,
            "binaryPath": "${workspaceFolder}/target/debug/soroban-debug"
          }
        ],
        "configurationSnippets": [
          {
            "label": "Soroban: Debug Contract",
            "description": "Launch Soroban contract debugger",
            "body": {
              "name": "Soroban: Debug Contract",
              "type": "soroban",
              "request": "launch",
              "contractPath": "${workspaceFolder}/target/wasm32-unknown-unknown/release/contract.wasm",
              "snapshotPath": "${workspaceFolder}/snapshot.json",
              "entrypoint": "main",
              "args": [],
              "trace": false,
              "binaryPath": "${workspaceFolder}/target/debug/soroban-debug"
            }
          }
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node ./dist/test/runTest.js",
    "build": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.75.0",
    "@vscode/debugprotocol": "^1.65.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@vscode/debugadapter": "^1.65.0",
    "events": "^3.3.0"
  }
}
